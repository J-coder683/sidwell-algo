# Sidwell — environment variables TEMPLATE
# Copy this file to `.env` (no .example suffix) and replace placeholders with real values.
# `.env` is gitignored; this `.env.example` file IS committed as a template — never put real keys here.

# FRED API Key (Required for fetching risk-free rates from FRED)
# Free signup: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here



# SEC User Agent (Required for US filings, format: "Name email@domain.com")
SEC_USER_AGENT=Your Name your.email@example.com

# Gemini API Key (Required for v0.2+ qualitative analysis)
# Free signup: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Drive folder path (Required for v0.2+ qualitative analysis)
# PDFs for each ticker go in: <SIDWELL_DRIVE_PATH>/<TICKER>/<file>.pdf
# Example (Windows/Google Drive): G:\My Drive\Sidwell-Drive
# Example (macOS): /Users/you/Library/CloudStorage/GoogleDrive-.../My Drive/Sidwell-Drive
# Defaults to ~/Sidwell-Drive if not set.
SIDWELL_DRIVE_PATH=G:\My Drive\Sidwell-Drive
