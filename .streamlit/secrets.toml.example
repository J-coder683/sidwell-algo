# Sidwell v0.6 — secrets template
# ─────────────────────────────────────────────────────────────────────────────
# SETUP INSTRUCTIONS:
#   Local dev:    Copy this file to .streamlit/secrets.toml and fill in your keys.
#                 The secrets.toml file is gitignored — never commit it.
#   Streamlit Cloud: Configure via app dashboard → Settings → Secrets (paste as TOML).
#
# Required for Gemini qualitative layer (optional — app degrades gracefully without it):
GEMINI_API_KEY = "your-gemini-api-key-here"
#
# Required for risk-free rate fetching from FRED (mandatory for DCF):
FRED_API_KEY = "your-fred-api-key-here"
#
