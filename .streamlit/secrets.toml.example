# Sidwell v0.7.6 — secrets template
# ─────────────────────────────────────────────────────────────────────────────
# SETUP INSTRUCTIONS:
#   Local dev:    Copy this file to .streamlit/secrets.toml and fill in your keys.
#                 The secrets.toml file is gitignored — never commit it.
#   Streamlit Cloud: Configure via app dashboard → Settings → Secrets (paste as TOML).
#
# Required for the DeepSeek V4 Pro qualitative layer (reads filings → JSON signals):
DEEPSEEK_API_KEY = "your-deepseek-api-key-here"
#
# Required for risk-free rate fetching from FRED (mandatory for DCF):
FRED_API_KEY = "your-fred-api-key-here"
#
# Optional — Supabase persistent cache (L2). When set, the multi-minute DeepSeek
# qualitative result survives Streamlit Cloud restarts/redeploys instead of being
# recomputed on every cold start. Leave blank to run file-cache-only (no change).
# SUPABASE_KEY must be the service_role secret key (server-side only; bypasses RLS
# so the public anon key stays locked out of the cache table). Never commit it.
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_KEY = "your-service_role-secret-key"
#
